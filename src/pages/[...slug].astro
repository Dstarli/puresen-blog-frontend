---
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const siteBase = 'https://puresen.com';
const canonicalUrl = `${siteBase}/blog/${post.slug}/`;
const ogImage = post.data.image?.url || `${siteBase}/wp-content/uploads/2026/04/puresen-favicon-512.png`;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{post.data.title} | Puresen</title>
  <meta name="description" content={post.data.description} />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:type" content="article" />
  <meta property="og:title" content={post.data.title} />
  <meta property="og:description" content={post.data.description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content="Puresen" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={post.data.title} />
  <meta name="twitter:description" content={post.data.description} />
  <meta name="twitter:image" content={ogImage} />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": post.data.title,
    "description": post.data.description,
    "image": ogImage,
    "author": { "@type": "Organization", "name": "Puresen", "url": siteBase },
    "publisher": { "@type": "Organization", "name": "Puresen", "url": siteBase, "logo": { "@type": "ImageObject", "url": `${siteBase}/wp-content/uploads/2026/04/puresen-favicon-512.png` } },
    "datePublished": post.data.pubDate,
    "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalUrl }
  })} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@600;700&family=Nunito+Sans:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <style is:global>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Nunito Sans', sans-serif; background: #f7f3ee; color: #513832; }
    header { background: rgba(255,250,247,.9); border-bottom: 1px solid rgba(81,56,50,.1); padding: 1.15rem 2rem; display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
    header a { color: #8d5154; text-decoration: none; font-weight: 800; }
    header a.brand { font-family: 'Comfortaa', sans-serif; color: #513832; font-size: 1.35rem; letter-spacing: -.06em; }
    article { max-width: 800px; margin: 3rem auto; padding: 0 1.25rem; }
    .hero-img { width: 100%; max-height: 430px; object-fit: cover; border-radius: 28px; margin-bottom: 2rem; box-shadow: 0 18px 55px rgba(81,56,50,.08); }
    .ps-byline { display: flex; align-items: center; gap: .6rem; margin-bottom: 1rem; }
    .ps-brand { background: #d88e92; color: white; font-size: .72rem; font-weight: 800; letter-spacing: .1em; text-transform: uppercase; padding: .28rem .7rem; border-radius: 999px; }
    .ps-cat { color: rgba(81,56,50,.58); font-size: .85rem; text-transform: capitalize; }
    h1 { font-family: 'Comfortaa', sans-serif; font-size: clamp(2rem, 6vw, 3.25rem); font-weight: 700; line-height: 1.18; letter-spacing: -.055em; margin-bottom: .8rem; }
    .meta { font-size: .86rem; color: rgba(81,56,50,.56); margin-bottom: 2rem; }
    .content { font-size: 1.04rem; line-height: 1.85; color: rgba(81,56,50,.78); }
    .content h2 { font-family: 'Comfortaa', sans-serif; font-size: 1.48rem; color: #513832; margin: 2.35rem 0 .9rem; padding-bottom: .55rem; border-bottom: 1px solid rgba(81,56,50,.1); letter-spacing: -.04em; }
    .content h3 { font-size: 1.12rem; font-weight: 800; color: #513832; margin: 1.45rem 0 .6rem; }
    .content p { margin-bottom: 1.15rem; }
    .content ul, .content ol { padding-left: 1.5rem; margin-bottom: 1.15rem; }
    .content li { margin-bottom: .5rem; }
    .content strong { color: #513832; }
    .content a { color: #8d5154; font-weight: 800; text-decoration: none; }
    .content a:hover { text-decoration: underline; }
    .ps-cta, .ps-caution { background: #fffaf7; border: 1px solid rgba(81,56,50,.1); border-radius: 24px; padding: 1.35rem; margin-top: 2rem; box-shadow: 0 12px 40px rgba(81,56,50,.07); }
    .ps-cta h3, .ps-caution h3 { font-size: 1.05rem; color: #8d5154; margin-bottom: .55rem; }
    .ps-cta p, .ps-caution p { margin: 0; color: rgba(81,56,50,.72); }
    footer { text-align: center; padding: 3rem 1rem; color: rgba(81,56,50,.52); font-size: .85rem; border-top: 1px solid rgba(81,56,50,.08); margin-top: 4rem; }
  </style>
</head>
<body>
  <header>
    <a href="/blog/">← Journal</a>
    <a class="brand" href="https://puresen.com">puresen</a>
  </header>
  <article>
    {post.data.image && <img class="hero-img" src={post.data.image.url} alt={post.data.image.alt} />}
    <h1>{post.data.title}</h1>
    <p class="meta">By {post.data.author} &middot; {new Date(post.data.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
    <div class="content">
      <Content />
    </div>
  </article>
  <footer>© {new Date().getFullYear()} Puresen. For aromatic use only. Not intended to diagnose, treat, cure, or prevent disease.</footer>
</body>
</html>
